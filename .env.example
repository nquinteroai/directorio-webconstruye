# ============================================================
# Directorio Webconstruye — variables de entorno
# Copia este archivo a `.env.local` y completa los valores.
# ============================================================

# --- Supabase (crea un proyecto NUEVO en https://supabase.com) ---
# Dónde encontrarlos: Project Settings → API (o "API Keys").
# URL del proyecto:
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Clave pública (se llama "anon public" o "Publishable key"):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave secreta de servidor (se llama "service_role" o "Secret key").
# NUNCA la expongas en el navegador ni la subas a git:
SUPABASE_SERVICE_ROLE_KEY=

# --- Sitio ---
# URL pública del sitio. En local: http://localhost:3000
# En producción: el dominio final (ej. https://directorio.webconstruye.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sincronización CRM → Directorio (opcional) ---
# Clave compartida del webhook de webconstruye-ventas
# (POST /api/internal/businesses). La misma clave se guarda en el Vault del
# Supabase del CRM. Sin esta variable el endpoint responde 503 (apagado).
# Genera una con: openssl rand -hex 32
SYNC_INTERNAL_KEY=
